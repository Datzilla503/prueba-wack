---
layout: ../layouts/MainLayout.astro
---

<!-- Hero Section -->
<section class="hero" style="background: linear-gradient(135deg, cyan, purple); padding: 60px 0;">
  <div class="content">
    <h1>Welcome to StreamCity</h1>
    <p>Discover the latest in gaming, events, and news.</p>
  </div>
</section>

<!-- Featured Event Card -->
<section class="featured-event">
  <div class="event-card" style="position: relative; overflow: hidden;">
    <img src="/path/to/event-image.jpg" alt="Featured Event" style="width:100%;">
    <div class="overlay" style="position:absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.6); display:flex; align-items:center; justify-content:center; color:white;">
      <h2>Featured Event</h2>
    </div>
  </div>
</section>

<!-- News Grid -->
<section class="news-grid">
  <h2>Latest News</h2>
  <div class="grid">
    <article>News Article 1</article>
    <article>News Article 2</article>
    <article>News Article 3</article>
  </div>
</section>

<!-- Upcoming Events Section -->
<section class="upcoming-events">
  <h2>Upcoming Events</h2>
  <ul>
    <li>Event 1</li>
    <li>Event 2</li>
    <li>Event 3</li>
  </ul>
</section>
